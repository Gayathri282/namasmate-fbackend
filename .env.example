# Server Port
PORT=5000

# MongoDB URI (Local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/sujood-mate

# JWT Secret for signing admin sessions
JWT_SECRET=your_jwt_signing_secret_key

# SMTP Nodemailer Settings (For order receipts and notifications)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user_id
SMTP_PASS=your_smtp_password
EMAIL_FROM=orders@sujoodmate.com

# NOTE: No admin is auto-seeded. Use POST /api/auth/register (only works when DB has 0 admins)
# to create your first admin account, then log in at /admin/login
