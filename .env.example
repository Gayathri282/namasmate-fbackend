# Server Port
PORT=5000

# MongoDB URI (Local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/namas-mate

# JWT Secret for signing admin sessions
JWT_SECRET=your_jwt_signing_secret_key

# Resend Email (Replaces nodemailer SMTP — much simpler!)
# Sign up free at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=your_resend_api_key_here

# The "from" email shown to customers
# Must be a domain you've verified in Resend (or use onboarding@resend.dev for testing)
EMAIL_FROM=orders@namasmate.com

# NOTE: No admin is auto-seeded. Use POST /api/auth/register (only works when DB has 0 admins)
# to create your first admin account, then log in at /admin/login
